<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f0f1a">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1a0a2e"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvProjectName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Pon Engine"
            android:textColor="#ff6b9d"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="monospace"/>

        <Button
            android:id="@+id/btnNewProject"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="New"
            android:textSize="12sp"
            android:backgroundTint="#2a1a3e"
            android:textColor="#a78bfa"/>

        <Button
            android:id="@+id/btnRun"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="▶ Run"
            android:textSize="12sp"
            android:backgroundTint="#ff6b9d"
            android:textColor="#fff"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <!-- Circle slot viewer -->
    <FrameLayout
        android:id="@+id/slotContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/navBar"/>

    <!-- Nav bar -->
    <LinearLayout
        android:id="@+id/navBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#0a0a14"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnPrev"
            android:layout_width="64dp"
            android:layout_height="48dp"
            android:text="◀"
            android:textSize="20sp"
            android:backgroundTint="#1a1a2e"
            android:textColor="#a78bfa"/>

        <TextView
            android:id="@+id/tvSlotIndex"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Slot 1 / 3"
            android:textColor="#888"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"/>

        <Button
            android:id="@+id/btnNext"
            android:layout_width="64dp"
            android:layout_height="48dp"
            android:text="▶"
            android:textSize="20sp"
            android:backgroundTint="#1a1a2e"
            android:textColor="#a78bfa"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
